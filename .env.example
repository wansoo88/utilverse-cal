# Site URL (subdomain)
NEXT_PUBLIC_SITE_URL=https://cal.utilverse.info

# Google Analytics 4 (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Formspree contact form ID
NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxxxxx

# Open Charge Map API key (free — https://openchargemap.org/site/develop/api)
# Register at https://openchargemap.org/site/profile/applications → instantly issued
NEXT_PUBLIC_OCM_API_KEY=

# Google AdSense (Phase 4)
# Must start with "ca-pub-" — the script is only injected when this format matches.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Amazon Associates tracking ID (e.g. utilverse-20).
# Applied automatically to every Amazon link rendered through AffiliateSection.
NEXT_PUBLIC_AMAZON_TAG=utilverse-20
